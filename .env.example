# Paperclip Railway template environment variables
# Copy this file to .env for local reference only.
# In Railway template composer, set these in service variables.

# Required
# Primary Postgres connection string from Railway managed postgres service.
DATABASE_URL=${{Postgres.DATABASE_URL}}
# Authentication/session signing secret for Better Auth (generated, keep hidden).
BETTER_AUTH_SECRET=${{secret(64, "abcdef0123456789")}}
# Bind host for container runtime.
HOST=0.0.0.0
# Internal app port exposed by container.
PORT=3100
# Enables serving Paperclip UI from the app service.
SERVE_UI=true
# Persistent filesystem root for Paperclip app state/config.
PAPERCLIP_HOME=/paperclip
# Deployment mode; authenticated requires login/auth flow.
PAPERCLIP_DEPLOYMENT_MODE=authenticated
# Exposure model for deployment; private is recommended default.
PAPERCLIP_DEPLOYMENT_EXPOSURE=private
# Public base URL used by Paperclip for callbacks/links.
PAPERCLIP_PUBLIC_URL=https://${{Paperclip.RAILWAY_PUBLIC_DOMAIN}}
# Canonical auth callback/redirect base URL for Better Auth.
BETTER_AUTH_BASE_URL=https://${{Paperclip.RAILWAY_PUBLIC_DOMAIN}}

# Optional
# OpenAI API key for OpenAI-backed agent/provider features.
OPENAI_API_KEY=
# Anthropic API key for Claude-backed agent/provider features.
ANTHROPIC_API_KEY=

# Basic auth for the wrapper (optional). Set both to enable.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# Cloudflare (Wrangler CLI)
# API token with Workers Scripts (Edit) permission minimum.
CLOUDFLARE_API_TOKEN=
# Account ID found in Cloudflare dashboard URL or overview page.
CLOUDFLARE_ACCOUNT_ID=

# Supabase CLI
# Access token from https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=